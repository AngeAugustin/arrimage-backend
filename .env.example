APP_ENV=dev
APP_DEBUG=1
APP_SECRET=change_me_in_production
DEFAULT_URI=http://localhost:8000
DATABASE_URL=postgresql://user:password@localhost:5432/arrimage_ifu?serverVersion=16&charset=utf8
JWT_SECRET_KEY=change_me_in_production_min_32_characters_long
JWT_PUBLIC_KEY=change_me_in_production_min_32_characters_long
JWT_PASSPHRASE=
JWT_ACCESS_TOKEN_TTL=3600
JWT_REFRESH_TOKEN_TTL=86400
JWT_SECURE_COOKIES=false
CORS_ALLOW_ORIGIN=http://localhost:5173

